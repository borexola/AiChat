@implements IAsyncDisposable
@inject IJSRuntime JS

<div class="chat-input-container">
    <div class="chat-input-wrapper @(ShowFiles ? "with-files" : "")">
        @if (ShowFiles && Files.Any())
        {
            <div class="attached-files">
                @foreach (var file in Files)
                {
                    var capturedFile = file;
                    var hasPreview = previewUrls.TryGetValue(file.Name, out var previewUrl) && previewUrl != null;
                    var isImage = file.ContentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase);
                    <div class="file-chip" @onclick="() => OnChipClick(capturedFile, previewUrl)" title="@(isImage ? "Click to expand" : "Click to download")">
                        @if (hasPreview)
                        {
                            <img src="@previewUrl" class="file-chip-preview" alt="@file.Name" />
                        }
                        else
                        {
                            <svg class="file-chip-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/>
                                <polyline points="13 2 13 9 20 9"/>
                            </svg>
                        }
                        <span class="file-name">@file.Name</span>
                        <button type="button" class="file-remove" @onclick="() => RemoveFile(capturedFile)" @onclick:stopPropagation="true" title="Remove">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="12" height="12">
                                <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                            </svg>
                        </button>
                    </div>
                }
            </div>
        }
        <textarea
            @bind="Message"
            @bind:event="oninput"
            @onkeydown="OnKeyDown"
            @ref="textareaRef"
            class="chat-input"
            placeholder="Type a message… or paste an image"
            rows="1"
            disabled="@Disabled"></textarea>
        <InputFile id="@hiddenFileInputId"
                   class="attach-input"
                   OnChange="OnFileSelected"
                   accept="@AllowedExtensionsAccept"
                   multiple />
        <button type="button"
                class="attach-btn"
                @onclick="OpenFileDialog"
                disabled="@Sending"
                title="Attach files">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21.44 11.05l-8.49 8.49a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48"></path>
            </svg>
        </button>
        <button class="send-btn"
                @onclick="OnSend"
                disabled="@((string.IsNullOrWhiteSpace(Message) && !Files.Any()) || Sending || Disabled)"
                title="Send message">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 2L11 13"></path>
                <path d="M22 2L15 22L11 13L2 9L22 2Z"></path>
            </svg>
        </button>
    </div>
    <div class="chat-input-hint">
        <span>Press Enter to send · Shift+Enter for new line · Paste image to attach</span>
    </div>
</div>

@code {
    [Parameter] public string Message { get; set; } = "";
    [Parameter] public EventCallback<string> OnSendMessage { get; set; }
    [Parameter] public EventCallback<List<IBrowserFile>> OnFilesSelected { get; set; }
    [Parameter] public bool Sending { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public List<IBrowserFile> Files { get; set; } = new();
    [Parameter] public bool ShowFiles { get; set; }
    [Parameter] public string[] AllowedExtensions { get; set; } = Array.Empty<string>();

    private ElementReference textareaRef;
    private readonly Dictionary<string, string?> previewUrls = new();
    private DotNetObjectReference<ChatInput>? pasteHandlerReference;
    private const int MaxHeight = 200;
    private const long MaxFileSizeBytes = 10L * 1024 * 1024;
    private readonly string hiddenFileInputId = $"chat-input-file-{Guid.NewGuid():N}";

    private string AllowedExtensionsAccept =>
        AllowedExtensions is { Length: > 0 } ext ? string.Join(",", ext) : string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("autoResizeTextarea", textareaRef, MaxHeight);

        pasteHandlerReference ??= DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("initPasteImageHandler", textareaRef, pasteHandlerReference);
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await OnSendMessage.InvokeAsync(Message);
        }
    }

    private async Task OnSend()
    {
        if (!string.IsNullOrWhiteSpace(Message) || Files.Any())
            await OnSendMessage.InvokeAsync(Message);
    }

    private async Task RemoveFile(IBrowserFile file)
    {
        previewUrls.Remove(file.Name);
        var newList = Files.Where(f => f.Name != file.Name).ToList();
        await OnFilesSelected.InvokeAsync(newList);
    }

    private async Task OpenFileDialog()
    {
        // Programmatically open the native file picker via the hidden InputFile.
        await JS.InvokeVoidAsync("triggerFileInputClickById", hiddenFileInputId);
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        var sourceFiles = e.GetMultipleFiles(50);
        if (sourceFiles.Count == 0)
            return;

        // Buffer each picked file into memory immediately. The IBrowserFile from
        // InputFile is backed by a SignalR-streamed channel; reading it later
        // (after a re-render or Send click) can fault the circuit.
        var buffered = new List<IBrowserFile>(sourceFiles.Count);
        foreach (var file in sourceFiles)
        {
            try
            {
                await using var stream = file.OpenReadStream(MaxFileSizeBytes);
                using var ms = new MemoryStream();
                await stream.CopyToAsync(ms);
                var bytes = ms.ToArray();
                buffered.Add(new InMemoryBrowserFile(file.Name, file.ContentType, bytes));

                // Generate a data-URL preview for images so the chip shows a thumbnail.
                if (file.ContentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase))
                {
                    var base64 = Convert.ToBase64String(bytes);
                    previewUrls[file.Name] = $"data:{file.ContentType};base64,{base64}";
                }
            }
            catch
            {
                // A bad file is skipped; never let it tear down the circuit.
            }
        }

        if (buffered.Count == 0)
            return;

        var merged = Files.Concat(buffered).ToList();
        await OnFilesSelected.InvokeAsync(merged);
    }

    [Microsoft.JSInterop.JSInvokable]
    public async Task HandlePastedImage(string name, string contentType, string dataUrl)
    {
        if (string.IsNullOrWhiteSpace(name) || string.IsNullOrWhiteSpace(contentType) || string.IsNullOrWhiteSpace(dataUrl))
            return;

        var commaIndex = dataUrl.IndexOf(',');
        if (commaIndex < 0 || commaIndex == dataUrl.Length - 1)
            return;

        byte[] bytes;
        try
        {
            bytes = Convert.FromBase64String(dataUrl[(commaIndex + 1)..]);
        }
        catch (FormatException)
        {
            return;
        }

        // JSInvokable callbacks run off the renderer's sync context, so marshal back
        // before mutating component state or invoking parent EventCallbacks.
        await InvokeAsync(async () =>
        {
            previewUrls[name] = dataUrl;

            var pastedFile = new InMemoryBrowserFile(name, contentType, bytes);
            var merged = Files.Concat<IBrowserFile>([pastedFile]).ToList();
            await OnFilesSelected.InvokeAsync(merged);
            StateHasChanged();
        });    }

    private async Task OnChipClick(IBrowserFile file, string? previewUrl)
    {
        var isImage = file.ContentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase);
        if (isImage && !string.IsNullOrEmpty(previewUrl))
        {
            await JS.InvokeVoidAsync("openImageModal", previewUrl, file.Name);
        }
        else
        {
            // For non-image files, read the bytes and trigger a browser download.
            try
            {
                await using var stream = file.OpenReadStream(MaxFileSizeBytes);
                using var ms = new MemoryStream();
                await stream.CopyToAsync(ms);
                var base64 = Convert.ToBase64String(ms.ToArray());
                var dataUrl = $"data:{file.ContentType};base64,{base64}";
                await JS.InvokeVoidAsync("downloadDataUrl", dataUrl, file.Name);
            }
            catch { /* best-effort */ }
        }
    }

    public ValueTask DisposeAsync()
    {
        pasteHandlerReference?.Dispose();
        return ValueTask.CompletedTask;
    }
}
